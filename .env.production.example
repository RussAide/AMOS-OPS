APP_ENV=production
AMOS_RUNTIME_MODE=production
AMOS_ENVIRONMENT_ID=amos-ops-production
CREDENTIAL_NAMESPACE=amos-ops/production
NODE_ENV=production
PORT=3000
PERSISTENT_ROOT=/app/persistent
RAILWAY_VOLUME_MOUNT_PATH=/app/persistent
DATABASE_PATH=/app/persistent/data/production/amos-ops.db
TRAINING_DATABASE_PATH=/app/persistent/data/production/training/amos-ops-training.db
UPLOAD_PATH=/app/persistent/uploads/production
TRAINING_UPLOAD_PATH=/app/persistent/uploads/production/training
BACKUP_PATH=/app/persistent/backups/production
AMOS_STORAGE_ENCRYPTION_REQUIRED=true
AMOS_STORAGE_KEY_PROVIDER=railway-sealed-variables-v1
AMOS_STORAGE_MIGRATION_MODE=none
AMOS_DATABASE_ACTIVE_KEY_ID=database-YYYY-MM
AMOS_DATABASE_KEY_MANIFEST_JSON={"database-YYYY-MM":"AMOS_DATABASE_KEY_V1"}
AMOS_DATABASE_KEY_V1=replace-with-sealed-32-byte-base64-key
AMOS_UPLOAD_ACTIVE_KEY_ID=upload-YYYY-MM
AMOS_UPLOAD_KEY_MANIFEST_JSON={"upload-YYYY-MM":"AMOS_UPLOAD_KEY_V1"}
AMOS_UPLOAD_KEY_V1=replace-with-sealed-32-byte-base64-key
AMOS_BACKUP_ACTIVE_KEY_ID=backup-YYYY-MM
AMOS_BACKUP_KEY_MANIFEST_JSON={"backup-YYYY-MM":"AMOS_BACKUP_KEY_V1"}
AMOS_BACKUP_KEY_V1=replace-with-sealed-32-byte-base64-key
APP_ID=amos-ops
APP_SECRET=replace-with-production-secret-from-production-vault
JWT_SECRET=replace-with-distinct-production-secret-from-production-vault
ALLOW_SELF_REGISTRATION=false
MFA_POLICY=required-all
DEPLOYMENT_APPROVAL_ID=replace-with-approved-production-release-id
DEPLOYMENT_CHANGE_REFERENCE=replace-with-production-change-reference
AMOS_ALLOWED_ORIGINS=https://amos-ops.com,https://www.amos-ops.com
AMOS_PRODUCTION_RELEASE_AUTHORIZED=false
AMOS_PRODUCTION_RELEASE_ID=
