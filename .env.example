# AMOS-OPS Production Environment Variables
# Copy to .env and set your actual values

NODE_ENV=production
PORT=3000

# Database
DATABASE_PATH=/app/data/amos-ops.db

# Security (change in production!)
JWT_SECRET=your-secret-key-change-me
APP_ID=amos-ops
APP_SECRET=your-app-secret

# Microsoft Graph (M8 integration)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
