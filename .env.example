# AMOS-OPS local development profile
# Copy this file to .env. Never copy credentials between environments.

APP_ENV=development
AMOS_RUNTIME_MODE=production
AMOS_ENVIRONMENT_ID=amos-ops-development
CREDENTIAL_NAMESPACE=amos-ops/development
NODE_ENV=development
PORT=3000

DATABASE_PATH=./data/development/amos-ops.db
TRAINING_DATABASE_PATH=./data/development/training/amos-ops-training.db
UPLOAD_PATH=./uploads/development
TRAINING_UPLOAD_PATH=./uploads/development/training
JWT_SECRET=
APP_ID=amos-ops
APP_SECRET=

ALLOW_SELF_REGISTRATION=true
MFA_POLICY=optional

DEPLOYMENT_APPROVAL_ID=
DEPLOYMENT_CHANGE_REFERENCE=
AMOS_ALLOWED_ORIGINS=http://localhost:3000

MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
