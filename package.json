    "report:dx1:qa": "node scripts/dx1-run-qa.mjs --root .. --output ../evidence",
    "package:dx1": "node scripts/dx1-seal-package.mjs --root .. --output ../package",
    "report:m1.1:login": "vitest run api/tests/login-evidence.test.ts --reporter=verbose",
