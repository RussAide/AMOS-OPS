    "report:m1.3:migrations": "node scripts/m13-verify-migrations.mjs",
    "verify:m1.3:evidence": "node --import tsx scripts/m13-verify-evidence.ts ../evidence",
    "report:m2.1:migrations": "node scripts/m21-verify-migrations.mjs",
    "report:m2.1:evidence": "node --import tsx scripts/m21-export-evidence.ts ../evidence",
    "report:m2.1:qa": "node scripts/m21-run-qa.mjs ../evidence/90_Manifest_and_QA",
