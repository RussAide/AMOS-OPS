  "scripts": {
    "dev": "vite",
    "build": "npm run schema:export && npm run build:client && npm run build:server",
    "schema:export": "node scripts/export-current-schema.mjs",
    "build:client": "vite build",
    "build:server": "esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --external:better-sqlite3 --external:bcryptjs --external:@hono/node-server --banner:js=\"import { createRequire } from 'module';import { fileURLToPath } from 'url';const require = createRequire(import.meta.url);const __filename = fileURLToPath(import.meta.url);const __dirname = fileURLToPath(new URL('.', import.meta.url));\"",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/boot.js",
    "start:server": "npm run start",
    "typecheck": "tsc -b --pretty false",
    "check": "npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude 'dist/**' --exclude 'dist-server/**' --exclude 'node_modules/**'",
    "test:dms1:review": "node --import tsx scripts/dms1-review-smoke.mjs",
    "test:dms1:built-runtime": "node scripts/dms1-built-runtime-smoke.mjs",
    "test:sidebar:built-runtime": "node --import tsx scripts/sidebar-built-deep-link-smoke.mjs",
    "report:dms1:qa": "node scripts/dms1-run-qa.mjs --root .. --output ../evidence",
    "verify": "npm run lint:strict && npm run typecheck && npm run test && npm run build",
    "env:validate": "node scripts/validate-environment.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-lifecycle.mjs migrate",
    "db:lifecycle": "node scripts/db-lifecycle.mjs",
    "db:push": "drizzle-kit push",
    "test:m1.1:reliability": "vitest run api/tests/cors-policy.test.ts api/tests/data-lifecycle.test.ts api/tests/http-client.test.ts api/tests/login-concurrency.test.ts api/tests/observability.test.ts api/tests/startup-policy.test.ts src/providers/resilient-fetch.test.ts",
    "test:m1.2:regulatory": "vitest run api/tests/m12-register-integration.test.ts api/tests/m12-clinical-policy.test.ts api/tests/m12-gro-policy.test.ts api/tests/m12-part2-policy.test.ts --reporter=verbose",
    "test:m1.3:mgma": "vitest run api/tests/m13-kpi-contract.test.ts api/tests/m13-mgma-integration.test.ts --reporter=verbose",
    "test:m2.1:ccmg": "vitest run api/tests/m21-care-path-contract.test.ts api/tests/m21-care-path-e2e.test.ts api/tests/m21-ccmg-contract.test.ts api/tests/m21-ccmg-integration.test.ts src/components/ccmg/ccmg-access.test.ts src/components/ccmg/ccmg-care-path-actions.test.tsx src/components/ccmg/ccmg-oversight-model.test.ts src/components/ccmg/ccmg-query-fallback.test.ts src/components/ccmg/ccmg-referral-detail-view.test.tsx src/components/ccmg/ccmg-workflow-actions.test.tsx --reporter=verbose",
