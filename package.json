    "report:m5.2:evidence": "node --import tsx scripts/m52-export-evidence.ts --root .. --output ../evidence",
    "verify:m5.2:evidence": "node --import tsx scripts/m52-verify-evidence.ts --root .. --output ../evidence",
    "report:m5.2:qa": "node scripts/m52-run-qa.mjs --root .. --output ../evidence",
    "package:m5.2": "node scripts/m52-seal-package.mjs --root .. --output ../package",
    "test:dx1": "vitest run api/tests/dx1-*.test.ts api/tests/dx1-*.test.tsx --reporter=verbose",
    "report:dx1:inherited": "node scripts/dx1-verify-inherited.mjs --root .. --output ../evidence",
    "report:dx1:evidence": "node --import tsx scripts/dx1-export-evidence.ts --root .. --output ../evidence",
