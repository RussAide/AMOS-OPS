APP_ENV=staging
AMOS_RUNTIME_MODE=production
AMOS_ENVIRONMENT_ID=amos-ops-staging
CREDENTIAL_NAMESPACE=amos-ops/staging
NODE_ENV=production
PORT=3000
DATABASE_PATH=/app/data/staging/amos-ops.db
TRAINING_DATABASE_PATH=/app/data/staging/training/amos-ops-training.db
UPLOAD_PATH=/app/uploads/staging
TRAINING_UPLOAD_PATH=/app/uploads/staging/training
APP_ID=amos-ops
APP_SECRET=replace-with-staging-secret-from-staging-vault
JWT_SECRET=replace-with-distinct-staging-secret-from-staging-vault
ALLOW_SELF_REGISTRATION=false
MFA_POLICY=required-all
DEPLOYMENT_APPROVAL_ID=replace-with-approved-staging-release-id
DEPLOYMENT_CHANGE_REFERENCE=replace-with-staging-change-reference
AMOS_ALLOWED_ORIGINS=https://staging.example.invalid

# DMS.1 release-review posture: Production pathway, isolated synthetic data,
# and live/external writes locked.
AMOS_REVIEW_DEPLOYMENT=true
AMOS_FINAL_GATE_OWNER_EMAIL=owner@amos-ops.invalid
AMOS_FINAL_GATE_CANDIDATE_ID=DMS.1
AMOS_BUILD_ID=replace-with-sealed-build-id
AMOS_SOURCE_DIGEST=replace-with-lowercase-sha256
AMOS_REVIEW_OWNER_PASSWORD_HASH=replace-with-bcrypt-hash
AMOS_REVIEW_OWNER_MFA_CODE=replace-with-private-six-digit-code
