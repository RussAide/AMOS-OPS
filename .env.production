# AMOS-OPS Production Environment Variables
# Copy to .env and customize for your deployment

# Application identity
APP_ID=amos-ops
APP_SECRET=change-me-to-a-random-secret

# JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret-min-32-chars

# Database
DATABASE_PATH=/app/data/amos-ops.db

# Server
PORT=3000
NODE_ENV=production
